# Copy this file to `.env` to enable the live Cerebras inference path.
# Without a key the app and CLI run in deterministic fallback mode.

# Your Cerebras API key (read only by the local Node proxy, never sent to the browser).
CEREBRAS_API_KEY=

# Hackathon model id.
CEREBRAS_MODEL=gemma-4-31b

# OpenAI-compatible Chat Completions base URL.
CEREBRAS_API_BASE=https://api.cerebras.ai/v1

# Optional: pin the local port (defaults to 5173, then 5174, 5175, 3000, 8080).
# PORT=5173
